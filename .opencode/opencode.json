{
  "$schema": "https://opencode.ai/config.json",
  "model": "anthropic/claude-sonnet-4-5",
  "small_model": "anthropic/claude-haiku-4-5",
  "instructions": [
    "AGENTS.md",
    ".opencode/skills/tdd-workflow/SKILL.md",
    ".opencode/skills/security-review/SKILL.md",
    ".opencode/skills/coding-standards/SKILL.md",
    ".opencode/skills/frontend-patterns/SKILL.md",
    ".opencode/skills/backend-patterns/SKILL.md",
    ".opencode/skills/e2e-testing/SKILL.md",
    ".opencode/skills/verification-loop/SKILL.md"
  ],
  "plugin": [],
  "skills": {
    "paths": [
      ".opencode/skills"
    ]
  },
  "agent": {
    "build": {
      "description": "Primary coding agent for Next.js 16 development work",
      "mode": "primary",
      "model": "anthropic/claude-sonnet-4-5",
      "tools": {
        "write": true,
        "edit": true,
        "bash": true,
        "read": true,
        "changed-files": true
      }
    },
    "planner": {
      "description": "Expert planning specialist for complex features and refactoring",
      "mode": "subagent",
      "model": "anthropic/claude-opus-4-5",
      "tools": {
        "read": true,
        "bash": true,
        "write": false,
        "edit": false
      }
    },
    "code-reviewer": {
      "description": "Expert code review specialist for React/Next.js/TypeScript",
      "mode": "subagent",
      "model": "anthropic/claude-opus-4-5",
      "tools": {
        "read": true,
        "bash": true,
        "write": false,
        "edit": false
      }
    },
    "security-reviewer": {
      "description": "Security vulnerability detection for Clerk auth, Convex, and API endpoints",
      "mode": "subagent",
      "model": "anthropic/claude-opus-4-5",
      "tools": {
        "read": true,
        "bash": true,
        "write": true,
        "edit": true
      }
    },
    "build-error-resolver": {
      "description": "Next.js 16 and TypeScript build error resolution specialist",
      "mode": "subagent",
      "model": "anthropic/claude-opus-4-5",
      "tools": {
        "read": true,
        "write": true,
        "edit": true,
        "bash": true
      }
    }
  }
}
